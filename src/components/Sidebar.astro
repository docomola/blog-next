---
import config from "@shConfig";
import AuthorCard from "./widgets/AuthorCard";
import DiscordCard from "./widgets/DiscordCard";
---

<!-- Sidebar -->
<aside class="flex w-full flex-col gap-5 lg:w-95">
  <!-- Author card -->
  <AuthorCard
    client:load
    image={config.author.avatarUrl}
    name={config.author.name}
    slug={config.author.name.toLowerCase().replace(/\s+/g, "")}
    description={config.author.bio}
    links={config.author.links}
    transition:name="sidebar"
  />

  <!-- Discord cards -->
  <a
    href="https://discord.gg/CWCjhRGJ2e"
    target="_blank"
    rel="noopener noreferrer"
  >
    <DiscordCard
      client:load
      title="Discord"
      subtitle="加入我的討論群組！"
      description="你遇到問題了嗎？加入我的群組「企鵝哥贛話中心」，和群裡的大神一起討論吧！"
    />
  </a>

  <!-- You can add more widgets here, we suggest adding a widget with the shadcn Card component like this: -->
  <!-- <Card className="border border-white/10 rounded-[14px] p-5 relative overflow-hidden" /> -->

  <!-- Never remove this slot, it's for the Table of Contents (ToC) - which will be sticky -->
  <slot />
</aside>
