---
import { cn } from "@lib/utils";

interface Props {
  labels: string[];
  class?: string;
}

const { labels, class: className } = Astro.props;
---

<div
  class={cn(
    "sh-builtin-components tabs-container my-6 rounded-lg overflow-hidden border border-white/10 bg-neutral-900",
    className,
  )}
>
  <!-- 分頁選擇 -->
  <div class="relative flex border-b border-white/10 px-2">
    {
      labels.map((label, index) => (
        <button
          type="button"
          class={cn(
            "tab-button relative z-10 px-4 py-2 text-sm font-medium transition-colors duration-300 outline-none",
            index === 0
              ? "text-green-400"
              : "text-gray-400 hover:text-gray-200",
          )}
          data-index={index}
        >
          {label}
        </button>
      ))
    }

    <div
      class="tab-sliding-line pointer-events-none absolute bottom-0 left-0 h-[2px] bg-green-500 transition-all duration-300 ease-out"
      style="width: 0; transform: translateX(0);"
    >
    </div>
  </div>

  <!-- 內容 -->
  <div class="tab-panels px-5 pt-2 pb-5">
    <slot />
  </div>
</div>

<script is:inline>
  (function setupSlidingTabs() {
    const containers = document.querySelectorAll(
      ".tabs-container:not([data-initialized-sliding])",
    );

    containers.forEach((container) => {
      container.setAttribute("data-initialized-sliding", "true");

      const buttons = container.querySelectorAll(".tab-button");
      const panels = container.querySelectorAll(".tab-panel");
      const line = container.querySelector(".tab-sliding-line");

      // 初始化底線位置
      const updateLine = (btn) => {
        line.style.width = `${btn.offsetWidth}px`;
        line.style.transform = `translateX(${btn.offsetLeft}px)`;
      };

      // 預設選中第一個
      if (buttons[0]) {
        // 使用 requestAnimationFrame 確保在 DOM 完全渲染後計算位置
        requestAnimationFrame(() => updateLine(buttons[0]));
      }

      buttons.forEach((btn, idx) => {
        btn.addEventListener("click", () => {
          buttons.forEach((b) => {
            // 重置所有按鈕的顏色
            b.classList.remove("text-green-400");
            b.classList.add("hover:text-gray-200");
            b.classList.add("text-gray-400");
          });
          // 設定當前按鈕的顏色
          btn.classList.add("text-green-400");
          btn.classList.remove("text-gray-400");
          btn.classList.remove("hover:text-gray-200");

          updateLine(btn);

          panels.forEach((p) => p.classList.add("hidden"));
          panels[idx].classList.remove("hidden");
        });
      });

      // 視窗縮放時重新計算位置，防止跑版
      window.addEventListener("resize", () => {
        const activeBtn = container.querySelector(".tab-button.text-green-400");
        if (activeBtn) updateLine(activeBtn);
      });
    });
  })();
</script>
