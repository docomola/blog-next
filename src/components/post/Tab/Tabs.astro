---
import { cn } from "@/lib/utils";

interface Props {
  labels: string[]; // 例如 ["Javascript", "Rust", "Typescript"]
  class?: string;
}

const { labels, class: className } = Astro.props;
const tabsId = `tabs-${Math.random().toString(36).substr(2, 9)}`;
---

<div
  class={cn(
    "sh-builtin-components tabs-container my-6 border border-white/10 rounded-xl bg-[#0D1117] overflow-hidden",
    className,
  )}
  data-tabs-id={tabsId}
>
  <div class="flex border-b border-white/10 bg-[#161B22] px-2">
    {
      labels.map((label, index) => (
        <button
          type="button"
          class={cn(
            "tab-button relative px-4 py-3 text-sm font-medium transition-all duration-200 outline-none",
            index === 0
              ? "active text-blue-400"
              : "text-gray-400 hover:text-gray-200",
          )}
          data-index={index}
        >
          {label}
          {/* 底部指示線 */}
          <div
            class={cn(
              "tab-indicator absolute bottom-0 left-0 h-[2px] w-full bg-blue-500 transition-opacity duration-200",
              index === 0 ? "opacity-100" : "opacity-0",
            )}
          />
        </button>
      ))
    }
  </div>

  <div class="tab-panels p-5">
    <slot />
  </div>
</div>

<script is:inline>
  (function setupTabs() {
    const containers = document.querySelectorAll(
      ".tabs-container:not([data-initialized])",
    );

    containers.forEach((container) => {
      container.setAttribute("data-initialized", "true");
      const buttons = container.querySelectorAll(".tab-button");
      const panels = container.querySelectorAll(".tab-panel");

      buttons.forEach((btn, idx) => {
        btn.addEventListener("click", () => {
          // 切換按鈕狀態
          buttons.forEach((b) => {
            b.classList.remove("text-blue-400", "active");
            b.classList.add("text-gray-400");
            b.querySelector(".tab-indicator").style.opacity = "0";
          });

          btn.classList.add("text-blue-400", "active");
          btn.classList.remove("text-gray-400");
          btn.querySelector(".tab-indicator").style.opacity = "1";

          // 切換面板顯示
          panels.forEach((p) => p.classList.add("hidden"));
          panels[idx].classList.remove("hidden");
        });
      });
    });
  })();
</script>
