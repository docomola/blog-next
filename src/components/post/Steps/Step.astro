---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div class="sh-builtin-components step-item group flex">
  <div
    class="mr-6 flex flex-col items-center rounded-full p-1 transition-colors duration-300 group-hover:bg-white/10 group-last:group-hover:bg-transparent"
  >
    <div
      class="step-number z-10 flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-white/10 bg-[#1A1A1A] text-sm font-semibold text-white transition-colors delay-150 duration-300 group-hover:bg-white/20"
    >
    </div>
    <div class="h-full w-[1px] bg-white/20 group-last:hidden"></div>
  </div>

  <div class="min-h-25 !py-2">
    <span class="text-xl leading-tight font-bold text-white">
      {title}
    </span>
    <div class="!mt-2 leading-relaxed text-gray-400">
      <slot />
    </div>
  </div>
</div>

<style>
  .step-item {
    counter-increment: step-counter;
  }

  .step-number::before {
    content: counter(step-counter);
  }
</style>
