---
import FileIcon from "./FileIcon.astro";
import type { FileIconType } from "./FileIcon.astro";

interface Props {
  name: string;
  icon?: FileIconType;
}

const { name, icon = "normal" } = Astro.props;
---

<div
  class="flex items-center py-1 hover:text-white transition-colors cursor-default px-2"
>
  <div class="w-4 mr-1"></div>

  <FileIcon class="w-5 h-5 mr-2 text-gray-500" icon={icon} />

  <span>{name}</span>
</div>
