---
import { File as FileIcon } from "@lucide/astro";

interface Props {
  name: string;
}
const { name } = Astro.props;
---

<div
  class="flex items-center py-1 hover:text-white transition-colors cursor-default"
>
  <div class="w-4 mr-1"></div>

  <FileIcon class="w-5 h-5 mr-2 text-gray-500" />

  <span>{name}</span>
</div>
