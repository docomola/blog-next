---
import { cn } from "@lib/utils";
import { Star, GitFork, Info, Circle } from "@lucide/astro";
import { Github } from "simple-icons-astro";

import I18nKey from "@i18n/i18nKey";
import i18n from "@i18n/translation";

interface Props {
  repo: `${string}/${string}`; // 格式為 "user/repo"
  class?: string;
}

const { repo, class: className } = Astro.props;

// 在建構階段抓取資料
const token = import.meta.env.GITHUB_TOKEN;
const response = await fetch(`https://api.github.com/repos/${repo}`, {
  headers: {
    Authorization: `Bearer ${token}`,
    "User-Agent": "Astro-Build",
  },
});

if (!response.ok) {
  throw new Error(`GitHub API error: ${response.status} for ${repo}`);
}

const data = await response.json();

// 語言顏色映射（可根據需求擴充）
const langColors: Record<string, string> = {
  TypeScript: "#3178c6",
  JavaScript: "#f1e05a",
  Astro: "#ff5a03",
  CSS: "#563d7c",
  HTML: "#e34c26",
};

const langColor = langColors[data.language] || "#8b949e";
---

<a
  href={data.html_url}
  target="_blank"
  rel="noopener noreferrer"
  class={cn(
    "sh-builtin-components block group px-5 py-5 rounded-xl border border-white/10 bg-[#0d1117] hover:border-blue-500/50 hover:bg-[#161b22] transition-all duration-300 no-underline",
    className,
  )}
>
  <div class="flex items-start justify-between mb-3">
    <div class="flex items-center gap-2">
      <Github class="w-5 h-5 text-gray-400" />
      <span class="text-green-400 font-semibold text-lg group-hover:underline">
        {data.name}
      </span>
    </div>
    <div
      class="px-2 py-0.5 rounded-full border border-white/10 text-[10px] text-gray-400 uppercase tracking-wider font-bold"
    >
      {i18n(I18nKey.github_card_public)}
    </div>
  </div>

  <p class="text-gray-400 text-base mb-4 line-clamp-2 leading-relaxed">
    {data.description || i18n(I18nKey.github_card_no_description)}
  </p>

  <div class="flex items-center gap-4 text-xs text-gray-500">
    {
      data.language && (
        <div class="flex items-center gap-1.5">
          <Circle class="w-3 h-3" fill={langColor} stroke="none" />
          <span>{data.language}</span>
        </div>
      )
    }

    <div
      class="flex items-center gap-1 hover:text-yellow-500 transition-colors"
    >
      <Star class="w-4 h-4" />
      <span>{data.stargazers_count.toLocaleString()}</span>
    </div>

    <div class="flex items-center gap-1 hover:text-blue-500 transition-colors">
      <GitFork class="w-4 h-4" />
      <span>{data.forks_count.toLocaleString()}</span>
    </div>

    <div class="hidden sm:block ml-auto italic">
      {i18n(I18nKey.github_card_updated_at)}
      {new Date(data.updated_at).toLocaleDateString()}
    </div>
  </div>
</a>
